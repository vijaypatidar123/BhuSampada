{
  "name": "bhusampada-local-mirror",
  "private": true,
  "version": "1.0.0",
  "description": "Local BhuSampada mirror with a Next.js rebuild workspace and FastAPI backend.",
  "scripts": {
    "dev:backend": "cd backend && uvicorn app.main:app --reload --port 8000",
    "dev:mirror": "cd backend && uvicorn app.main:app --reload --port 8000",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "lint:frontend": "npm --prefix frontend run lint"
  }
}
